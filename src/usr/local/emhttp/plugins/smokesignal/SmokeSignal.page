Menu="Main"
Title="SmokeSignal"
Icon="smokesignal.png"
---
<style>
  .ss-box{margin:8px 0}
  .ss-btn{cursor:pointer}
  #ss-reboot-btn{margin-left:8px}
</style>

<div class="ss-box">
  <span>Run a pre-reboot health check &mdash; will the server come back up clean?</span>
  <div style="margin-top:10px">
    <input type="button" id="ss-main-btn" class="ss-btn" value="SmokeSignal: Check now" onclick="smokesignalRun()">
  </div>
</div>

<script>
function smokesignalRun(){
  var url='/plugins/smokesignal/include/SmokeSignalReport.php';
  if (typeof openBox === 'function') {
    openBox(url, 'SmokeSignal — Pre-Reboot Check', 640, 880, true);
  } else {
    window.open(url, '_blank', 'width=920,height=720,scrollbars=yes');
  }
}

$(function(){
  try {
    // best-effort: drop a compact SmokeSignal button right next to the Reboot button
    var reboot = $('input[type=button], button, a').filter(function(){
      var v  = ($(this).val() || $(this).text() || '').trim().toLowerCase();
      var oc = ($(this).attr('onclick') || '').toLowerCase();
      return v === 'neu starten' || v === 'reboot'
          || oc.indexOf('reboot(') > -1 || oc.indexOf("'reboot'") > -1 || oc.indexOf('"reboot"') > -1;
    }).first();
    if (reboot.length && !$('#ss-reboot-btn').length) {
      var clone = $('<input type="button" id="ss-reboot-btn" class="ss-btn" value="SmokeSignal">');
      clone.on('click', smokesignalRun);
      reboot.after(clone);
    }
  } catch(e) {}
});
</script>
